<Window x:Class="PdfCollector.Presentation.Views.HealthCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PdfCollector.Presentation.ViewModels"
        xmlns:cv="clr-namespace:PdfCollector.Presentation.Converters"
        Title="Sistem Durumu"
        Width="520" Height="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <cv:AppBoolToVisConverter       x:Key="BoolToVis"/>
        <cv:AppHealthToColorConverter   x:Key="HealthToColor"/>
        <cv:AppHealthToBgColorConverter x:Key="HealthToBgColor"/>
        <cv:AppHealthToIconConverter    x:Key="HealthToIcon"/>
    </Window.Resources>

    <Border Margin="8">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="20"
                              ShadowDepth="2" Direction="270"/>
        </Border.Effect>
        <Border CornerRadius="8" Background="{StaticResource BgPageBrush}" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>   <!-- Header  -->
                    <RowDefinition Height="*"/>    <!-- Content -->
                    <RowDefinition Height="Auto"/> <!-- İndirme -->
                    <RowDefinition Height="52"/>   <!-- Footer  -->
                </Grid.RowDefinitions>

                <!-- ── HEADER ──────────────────────────────────────────── -->
                <Border Grid.Row="0"
                        Background="{StaticResource TitleBarBrush}"
                        MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                    Margin="20,0,0,0" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="5"
                                    Background="#33FFFFFF" Margin="0,0,12,0">
                                <TextBlock Text="🔍" FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Sistem Durumu"
                                           Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="Uygulama bileşen ve yazdırma kontrolleri"
                                           Foreground="#CCFFFFFF" FontSize="11" Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="50" Height="40" Margin="0,0,10,0"
                                Style="{StaticResource TitleBarCloseButton}"
                                Click="BtnClose_Click">
                            <Path Data="M 0,0 L 10,10 M 0,10 L 10,0"
                                  Stroke="White" StrokeThickness="1"
                                  Width="10" Height="10"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ── KONTROL LİSTESİ ──────────────────────────────────── -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12,16,4">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:HealthCheckItemViewModel}">
                                <Border Background="{StaticResource BgSurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="14,12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <!-- Başlık satırı -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text=" — "
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </StackPanel>

                                            <!-- Durum rozeti -->
                                            <Border Grid.Column="1" CornerRadius="10" Padding="10,3"
                                                    Background="{Binding StatusBgColor}">
                                                <TextBlock Text="{Binding StatusIcon}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{Binding StatusColor}"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>

                                        <!-- Detay mesajı -->
                                        <TextBlock Text="{Binding Detail}"
                                                   FontSize="11" TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="0,6,0,0"
                                                   Visibility="{Binding HasDetail, Converter={StaticResource BoolToVis}}"/>

                                        <!-- İndir butonu (sadece SumatraPDF için) -->
                                        <Button Content="⬇  SumatraPDF İndir"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding DataContext.DownloadCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                Padding="14,7" Margin="0,8,0,0"
                                                HorizontalAlignment="Left"
                                                Visibility="{Binding CanDownload, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ── İNDİRME İLERLEMESİ ──────────────────────────────── -->
                <Border Grid.Row="2"
                        Background="{StaticResource AccentLightBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16,12"
                        Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding DownloadStatus}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="İptal"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding CancelCommand}"
                                    Padding="12,5"/>
                        </Grid>
                        <ProgressBar Style="{StaticResource ModernProgressBar}"
                                     Height="5"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding DownloadProgress, Mode=OneWay}"/>
                    </StackPanel>
                </Border>

                <!-- ── FOOTER ───────────────────────────────────────────── -->
                <Border Grid.Row="3"
                        Background="{StaticResource BgSurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Genel durum rozeti -->
                        <Border Grid.Column="0" CornerRadius="10" Padding="10,4"
                                HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding AllHealthy,
                                    Converter={StaticResource HealthToBgColor}}"/>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding AllHealthy,
                                               Converter={StaticResource HealthToIcon}}"
                                           FontSize="12" Margin="0,0,5,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding OverallText}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{Binding AllHealthy,
                                               Converter={StaticResource HealthToColor}}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Grid.Column="1"
                                Content="Yenile"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding RefreshCommand}"
                                Padding="14,8"
                                VerticalAlignment="Center"/>

                        <Button Grid.Column="3"
                                Content="Kapat"
                                Style="{StaticResource PrimaryButton}"
                                Padding="14,8"
                                VerticalAlignment="Center"
                                Click="BtnClose_Click"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>
