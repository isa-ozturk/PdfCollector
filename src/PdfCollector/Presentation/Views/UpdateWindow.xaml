<Window x:Class="PdfCollector.Presentation.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cv="clr-namespace:PdfCollector.Presentation.Converters"
        Title="Güncelleme Mevcut"
        Width="660" Height="500"
        MinWidth="520" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPageBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        ResizeMode="CanResize">

    <Window.Resources>
        <cv:AppBoolToVisConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ─── HEADER ──────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,18,24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Güncelleme ikonu -->
                <Border Grid.Column="0"
                        Width="44" Height="44"
                        CornerRadius="10"
                        Background="{StaticResource AccentLightBrush}">
                    <TextBlock Text="&#11014;"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource AccentBrush}"/>
                </Border>

                <!-- Başlık -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="Yeni Sürüm Mevcut"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}">
                            <Run Text="{Binding CurrentVersion, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="  →  " FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource SuccessBrush}">
                            <Run Text="{Binding NewVersion, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Yeni badge -->
                <Border Grid.Column="3"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="4" Padding="10,4"
                        VerticalAlignment="Center">
                    <TextBlock Text="YENİ" FontSize="10" FontWeight="Bold"
                               Foreground="White"/>
                </Border>
            </Grid>
        </Border>

        <!-- ─── SÜRÜM NOTLARI ────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{StaticResource BgSurfaceBrush}"
                Margin="16,10,16,0"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource BgElevatedBrush}"
                        CornerRadius="8,8,0,0"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="14,8">
                    <TextBlock Text="SÜRÜM NOTLARI"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="18,14">
                    <TextBox Text="{Binding ReleaseNotes, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextSecondaryBrush}"
                             FontFamily="Segoe UI"
                             FontSize="12.5"
                             AcceptsReturn="True"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ─── FOOTER ──────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- İndirme progress -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center"
                            Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding DownloadStatus}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ProgressBar Margin="0,5,20,0" Height="3"
                                 Style="{StaticResource ModernProgressBar}"
                                 IsIndeterminate="True"/>
                </StackPanel>

                <TextBlock Grid.Column="0"
                           Text="Güncelleme yüklenince uygulama yeniden başlar."
                           FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}"/>

                <Button Grid.Column="1" x:Name="BtnLater"
                        Content="Sonra"
                        Style="{StaticResource SecondaryButton}"
                        IsEnabled="{Binding IsIdle}"
                        Padding="18,9"
                        Click="BtnLater_Click"/>

                <Button Grid.Column="3" x:Name="BtnUpdate"
                        Content="&#11014;  Şimdi Güncelle"
                        Style="{StaticResource PrimaryButton}"
                        IsEnabled="{Binding IsIdle}"
                        Padding="20,9"
                        Click="BtnUpdate_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
