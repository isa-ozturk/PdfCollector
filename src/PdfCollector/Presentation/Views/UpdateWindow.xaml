<Window x:Class="PdfCollector.Presentation.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cv="clr-namespace:PdfCollector.Presentation.Converters"
        xmlns:helpers="clr-namespace:PdfCollector.Presentation.Helpers"
        Title="Güncelleme Mevcut"
        Width="780" Height="580"
        MinWidth="620" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        BorderThickness="0"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="Segoe UI"
        ResizeMode="CanResizeWithGrip"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <cv:AppBoolToVisConverter x:Key="BoolToVis"/>
        <cv:AppInverseBoolToVisConverter x:Key="InvBoolToVis"/>

        <!-- Kenar çubuğu liste öğesi -->
        <Style x:Key="VersionListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="6,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="Stripe" Grid.Column="0"
                                        Width="3" CornerRadius="2"
                                        Background="{StaticResource AccentBrush}"
                                        Visibility="Hidden" Margin="0,2"/>
                                <ContentPresenter Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EBEBEB"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EBEBEB"/>
                                <Setter TargetName="Stripe" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="VersionItemTemplate">
            <TextBlock Text="{Binding Header}" FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </DataTemplate>

        <!-- Primary buton -->
        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost buton -->
        <Style x:Key="GhostActionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EBEBEB"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Dış kart + gölge -->
    <Border Margin="14"
            Background="{StaticResource BgSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="2" Opacity="0.18" Direction="270" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── HEADER ──────────────────────────────────────────── -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="#106EBE" Offset="0.5"/>
                        <GradientStop Color="#005A9E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="24,18,16,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- İkon -->
                    <Border Grid.Column="0"
                            Width="50" Height="50" CornerRadius="13"
                            Background="#33FFFFFF" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Path Data="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M7 10l5 5 5-5 M12 15V3"
                              Stroke="White" StrokeThickness="2"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Stretch="Uniform" Width="22" Height="22"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Başlık + sürüm karşılaştırması -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Yeni bir güncelleme bulundu!"
                                   FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                            <!-- Mevcut -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Mevcut sürüm:" FontSize="12"
                                           Foreground="#CCFFFFFF" VerticalAlignment="Center"/>
                                <Border Background="#33FFFFFF" CornerRadius="10"
                                        Padding="9,2" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CurrentVersion, Mode=OneWay}"
                                               FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <!-- Ok -->
                            <Path Data="M5 12h14 M12 5l7 7-7 7"
                                  Stroke="White" StrokeThickness="1.6"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Stretch="Uniform" Width="14" Height="14"
                                  Margin="12,0" VerticalAlignment="Center" Opacity="0.8"/>
                            <!-- Yeni -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Yeni sürüm:" FontSize="12"
                                           Foreground="#CCFFFFFF" VerticalAlignment="Center"/>
                                <Border Background="White" CornerRadius="10"
                                        Padding="10,2" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding NewVersion, Mode=OneWay}"
                                               FontSize="12" FontWeight="Bold" Foreground="#0078D4"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Kapat -->
                    <Button Grid.Column="2" Width="44" Height="36"
                            Margin="0,6,4,0" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" VerticalAlignment="Top"
                            Click="BtnLater_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="7">
                                    <Path Data="M18 6L6 18 M6 6l12 12"
                                          Stroke="White" StrokeThickness="1.8"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stretch="Uniform" Width="12" Height="12"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ── GÖVDE: kenar çubuğu + içerik ─────────────────── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Kenar çubuğu -->
                <Border Grid.Column="0"
                        Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Sürüm Notları"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="18,14,18,6"/>
                        <ListBox x:Name="VersionsList"
                                 ItemsSource="{Binding ReleaseTabItems}"
                                 SelectedIndex="0"
                                 ItemContainerStyle="{StaticResource VersionListItemStyle}"
                                 ItemTemplate="{StaticResource VersionItemTemplate}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </Border>

                <!-- İçerik: markdown sürüm notları -->
                <Border Grid.Column="1" Background="{StaticResource BgSurfaceBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBlock Margin="26,18,26,18"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   LineHeight="22"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   helpers:MarkdownHelper.Markdown="{Binding SelectedItem.Content, ElementName=VersionsList}"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ── FOOTER ────────────────────────────────────────── -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgElevatedBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="24,13">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Bilgi / indirme durumu -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding DownloadStatus}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <ProgressBar Margin="0,5,20,0" Height="3"
                                         Style="{StaticResource ModernProgressBar}"
                                         IsIndeterminate="True"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsDownloading, Converter={StaticResource InvBoolToVis}}"
                                    VerticalAlignment="Center">
                            <Path Data="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10Z M12 16v-4 M12 8h.01"
                                  Stroke="{StaticResource AccentBrush}" StrokeThickness="1.6"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Stretch="Uniform" Width="15" Height="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Bu güncellemeyi yüklemeniz önerilir."
                                       FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Butonlar -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnLater" Content="Daha Sonra"
                                Style="{StaticResource GhostActionButton}"
                                IsEnabled="{Binding IsIdle}"
                                Margin="0,0,8,0"
                                Click="BtnLater_Click"/>
                        <Button x:Name="BtnUpdate"
                                Style="{StaticResource PrimaryActionButton}"
                                IsEnabled="{Binding IsIdle}"
                                Click="BtnUpdate_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M7 10l5 5 5-5 M12 15V3"
                                      Stroke="White" StrokeThickness="1.8"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Stretch="Uniform" Width="14" Height="14"
                                      Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Şimdi Güncelle" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── İNDİRME OVERLAY ───────────────────────────────── -->
            <Border Grid.Row="0" Grid.RowSpan="3"
                    Background="#70000000"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"
                    CornerRadius="12">
                <Border Background="{StaticResource BgSurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Width="300" Height="160"
                        CornerRadius="10"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
                        <ProgressBar Width="240" Height="4" IsIndeterminate="True"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="{StaticResource BgElevatedBrush}"
                                     BorderThickness="0"/>
                        <TextBlock Text="{Binding DownloadStatus}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,16,0,4" HorizontalAlignment="Center"/>
                        <TextBlock Text="Lütfen bekleyin..."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
