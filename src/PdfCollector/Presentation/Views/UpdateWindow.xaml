<Window x:Class="PdfCollector.Presentation.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cv="clr-namespace:PdfCollector.Presentation.Converters"
        Title="Güncelleme Mevcut"
        Width="700" Height="540"
        MinWidth="560" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        BorderThickness="0"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="Segoe UI"
        ResizeMode="CanResizeWithGrip"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <cv:AppBoolToVisConverter x:Key="BoolToVis"/>
        <cv:AppInverseBoolToVisConverter x:Key="InvBoolToVis"/>

        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostActionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgElevatedBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Dış kart + gölge -->
    <Border Margin="14"
            Background="{StaticResource BgSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.18" Direction="270" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── HEADER ──────────────────────────────────────────── -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="#106EBE" Offset="0.5"/>
                        <GradientStop Color="#005A9E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="24,20,16,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- İkon -->
                    <Border Grid.Column="0"
                            Width="52" Height="52" CornerRadius="13"
                            Background="#33FFFFFF" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Path Data="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M7 10l5 5 5-5 M12 15V3"
                              Stroke="White" StrokeThickness="2"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Stretch="Uniform" Width="24" Height="24"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Başlık + sürüm karşılaştırması -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Yeni Sürüm Mevcut"
                                   FontSize="19" FontWeight="SemiBold" Foreground="White"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Mevcut" FontSize="12" Foreground="#CCFFFFFF" VerticalAlignment="Center"/>
                                <TextBlock Text=" "/>
                                <Border Background="#33FFFFFF" CornerRadius="10" Padding="9,2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CurrentVersion, Mode=OneWay}"
                                               FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <Path Data="M5 12h14 M12 5l7 7-7 7"
                                  Stroke="White" StrokeThickness="1.6"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Stretch="Uniform" Width="14" Height="14"
                                  Margin="12,0" VerticalAlignment="Center" Opacity="0.8"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Yeni" FontSize="12" Foreground="#CCFFFFFF" VerticalAlignment="Center"/>
                                <TextBlock Text=" "/>
                                <Border Background="White" CornerRadius="10" Padding="10,2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding NewVersion, Mode=OneWay}"
                                               FontSize="12" FontWeight="Bold" Foreground="#0078D4"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Kapat butonu -->
                    <Button Grid.Column="2"
                            Width="46" Height="38" Margin="0,8,4,0"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" VerticalAlignment="Top"
                            Click="BtnLater_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="7">
                                    <Path Data="M18 6L6 18 M6 6l12 12"
                                          Stroke="White" StrokeThickness="1.8"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stretch="Uniform" Width="13" Height="13"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ── SÜRÜM NOTLARI ─────────────────────────────────── -->
            <Border Grid.Row="1" Background="{StaticResource BgSurfaceBrush}">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource BgElevatedBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="24,10">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8"
                                  Stroke="{StaticResource AccentBrush}" StrokeThickness="1.6"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Stretch="Uniform" Width="14" Height="14"
                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="SÜRÜM NOTLARI"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TextBox Text="{Binding ReleaseNotes, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextSecondaryBrush}"
                                 FontFamily="Segoe UI" FontSize="13"
                                 AcceptsReturn="True" Margin="24,16"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ── FOOTER ────────────────────────────────────────── -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgElevatedBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sol: bilgi veya indirme ilerleme -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding DownloadStatus}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <ProgressBar Margin="0,6,20,0" Height="3"
                                         Style="{StaticResource ModernProgressBar}"
                                         IsIndeterminate="True"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsDownloading, Converter={StaticResource InvBoolToVis}}"
                                    VerticalAlignment="Center">
                            <Path Data="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10Z M12 16v-4 M12 8h.01"
                                  Stroke="{StaticResource AccentBrush}" StrokeThickness="1.6"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Stretch="Uniform" Width="15" Height="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Güncelleme yüklenince uygulama yeniden başlar."
                                       FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Sağ: butonlar -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnLater" Content="Sonra"
                                Style="{StaticResource GhostActionButton}"
                                IsEnabled="{Binding IsIdle}"
                                Margin="0,0,8,0"
                                Click="BtnLater_Click"/>
                        <Button x:Name="BtnUpdate"
                                Style="{StaticResource PrimaryActionButton}"
                                IsEnabled="{Binding IsIdle}"
                                Click="BtnUpdate_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M7 10l5 5 5-5 M12 15V3"
                                      Stroke="White" StrokeThickness="1.8"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Stretch="Uniform" Width="14" Height="14"
                                      Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Şimdi Güncelle" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── YÜKLEME OVERLAY ───────────────────────────────── -->
            <Border Grid.Row="0" Grid.RowSpan="3"
                    Background="#70000000"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"
                    CornerRadius="12">
                <Border Background="{StaticResource BgSurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Width="300" Height="160"
                        CornerRadius="10"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
                        <ProgressBar Width="240" Height="4" IsIndeterminate="True"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="{StaticResource BgElevatedBrush}"
                                     BorderThickness="0"/>
                        <TextBlock Text="{Binding DownloadStatus}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,16,0,4" HorizontalAlignment="Center"/>
                        <TextBlock Text="Lütfen bekleyin..."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
