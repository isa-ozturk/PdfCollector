<Window x:Class="PdfCollector.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cv="clr-namespace:PdfCollector.Presentation.Converters"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="PDF Toplayıcı"
        Width="840" Height="720"
        MinWidth="680" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPageBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow">

    <!-- Windows 11-style custom chrome -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"
                            GlassFrameThickness="0"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <cv:AppBoolToVisConverter        x:Key="BoolToVis"/>
        <cv:AppInverseBoolToVisConverter  x:Key="InvBoolToVis"/>
        <cv:AppLogLevelToBrushConverter   x:Key="LevelToBrush"/>
        <cv:AppLogLevelToIconConverter    x:Key="LevelToIcon"/>
        <cv:AppIntToVisConverter          x:Key="IntToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>     <!-- Title bar         -->
            <RowDefinition Height="Auto"/>   <!-- Hero Header       -->
            <RowDefinition Height="Auto"/>   <!-- Dir picker        -->
            <RowDefinition Height="Auto"/>   <!-- Options           -->
            <RowDefinition Height="Auto"/>   <!-- Actions + prog    -->
            <RowDefinition Height="*"/>      <!-- Log               -->
            <RowDefinition Height="Auto"/>   <!-- Status bar        -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════
             TITLE BAR — Mavi gradyan, özel pencere kontrolleri
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource TitleBarBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- İkon + başlık  -->
                    <ColumnDefinition Width="*"/>      <!-- Sürükle alanı  -->
                    <ColumnDefinition Width="Auto"/>   <!-- Pencere tuşları -->
                </Grid.ColumnDefinitions>

                <!-- Sol: ikon + başlık -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="14,0,0,0">
                    <Border Width="22" Height="22" CornerRadius="5"
                            Background="#20FFFFFF" Margin="0,0,8,0">
                        <TextBlock Text="&#128230;"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="PDF Toplayıcı"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Orta: sürüklenebilir alan (WindowChrome tarafından handle edilir) -->
                <Border Grid.Column="1" Background="Transparent"/>

                <!-- Sağ: pencere kontrol tuşları -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Stretch">

                    <!-- Küçült -->
                    <Button x:Name="BtnMinimize"
                            Style="{StaticResource TitleBarButton}"
                            Content="&#xE921;"
                            ToolTip="Küçült"
                            Click="BtnMinimize_Click"/>

                    <!-- Büyüt / Geri yükle -->
                    <Button x:Name="BtnMaximize"
                            Style="{StaticResource TitleBarButton}"
                            Content="&#xE922;"
                            ToolTip="Büyüt"
                            Click="BtnMaximize_Click"/>

                    <!-- Kapat -->
                    <Button x:Name="BtnClose"
                            Style="{StaticResource TitleBarCloseButton}"
                            Content="&#xE8BB;"
                            ToolTip="Kapat"
                            Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             HERO HEADER — Uygulama kimliği + renkli aksanlar
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="22,14,14,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Sol: logo alanı + başlık + açıklama -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Mavi gradyan logo kutusu -->
                    <Border Width="46" Height="46" CornerRadius="12" Margin="0,0,14,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0078D4" Offset="0"/>
                                <GradientStop Color="#1E90FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#0078D4" Opacity="0.35"
                                              BlurRadius="10" ShadowDepth="2"/>
                        </Border.Effect>
                        <TextBlock Text="&#128230;"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="PDF Toplayıcı"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Alt klasörlerdeki PDF dosyalarını ZIP arşivine toplar ve yazdırır"
                                   FontSize="11.5"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Sağ: PDF badge + güncelleme + hakkında -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- PDF sayısı — renkli pill -->
                    <Border CornerRadius="12" Padding="10,4"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding FoundCount, Converter={StaticResource IntToVis}, Mode=OneWay}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#EBF3FB" Offset="0"/>
                                <GradientStop Color="#D6EAFC" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#128230; " FontSize="11"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}">
                                <Run Text="{Binding FoundCount, Mode=OneWay}"/>
                                <Run Text=" PDF bulundu"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Güncelleme butonu -->
                    <Button x:Name="BtnUpdate"
                            Style="{StaticResource UpdateButton}"
                            Content="{Binding UpdateButtonLabel, Mode=OneWay}"
                            Foreground="{Binding UpdateButtonColor, Mode=OneWay}"
                            IsEnabled="{Binding IsUpdateButtonEnabled, Mode=OneWay}"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                            Click="BtnUpdate_Click"/>

                    <!-- Hakkında butonu -->
                    <Button x:Name="BtnInfo"
                            Style="{StaticResource IconButton}"
                            Content="&#9432;"
                            VerticalAlignment="Center"
                            Click="BtnInfo_Click"
                            ToolTip="Uygulama hakkında"/>

                    <!-- Hakkında popup -->
                    <Popup x:Name="InfoPopup"
                           PlacementTarget="{Binding ElementName=BtnInfo}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           HorizontalOffset="-230">
                        <Border Background="{StaticResource BgSurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="20,16"
                                Width="290"
                                Margin="0,4,0,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.12"
                                                  BlurRadius="20" ShadowDepth="4"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Border Width="36" Height="36" CornerRadius="8"
                                            Margin="0,0,10,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#0078D4" Offset="0"/>
                                                <GradientStop Color="#1E90FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="&#128230;" FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="PDF Toplayıcı"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}">
                                            <Run Text="{Binding AppVersion, Mode=OneWay}"/>
                                            <Run Text=" · 2026"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,10"/>

                                <TextBlock TextWrapping="Wrap" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}">
                                    Alt klasörlerdeki PDF dosyalarını tarayarak tek bir ZIP
                                    arşivine toplar. Arşivdeki dosyaları doğrudan yazıcıya gönderebilir.
                                </TextBlock>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Geliştirici"
                                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="İsa Öztürk"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="İletişim"
                                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="isa.ozturk@lenze.com"
                                               FontSize="11" Foreground="{StaticResource AccentBrush}"
                                               Cursor="Hand"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             KAYNAK KLASÖR
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}"
                Margin="18,12,18,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Renkli başlık etiketi -->
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Border Width="3" CornerRadius="2"
                            Background="{StaticResource AccentBrush}"
                            Margin="0,0,7,0"/>
                    <TextBlock Text="KAYNAK KLASÖR"
                               FontSize="10.5" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource BgElevatedBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="12,9">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#128193;  "
                                       FontSize="12"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SourceDirectory}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Button Grid.Column="2"
                            Content="Gözat..."
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding BrowseCommand}"
                            Padding="16,9"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             SEÇENEKLER — Renkli ikonlarla 3 kart
        ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3" Margin="18,8,18,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Klasörleri Sil -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Width="24" Height="24" CornerRadius="6"
                                    Background="{StaticResource ErrorLightBrush}"
                                    Margin="0,0,8,0">
                                <TextBlock Text="&#128465;" FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Klasörleri Sil"
                                       FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Sadece PDF içeren klasörleri kaldır"
                                   FontSize="10.5"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1"
                              Style="{StaticResource ToggleCheckBox}"
                              IsChecked="{Binding DeleteAfterZip}"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Log Kaydet -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Width="24" Height="24" CornerRadius="6"
                                    Background="{StaticResource WarningLightBrush}"
                                    Margin="0,0,8,0">
                                <TextBlock Text="&#128196;" FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Log Kaydet"
                                       FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text=".log dosyasına işlem geçmişini yaz"
                                   FontSize="10.5"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1"
                              Style="{StaticResource ToggleCheckBox}"
                              IsChecked="{Binding SaveLog}"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Bitince Kapat -->
            <Border Grid.Column="4" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Width="24" Height="24" CornerRadius="6"
                                    Background="{StaticResource AccentLightBrush}"
                                    Margin="0,0,8,0">
                                <TextBlock Text="&#10006;" FontSize="11"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Bitince Kapat"
                                       FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="İşlem bitince uygulamayı kapat"
                                   FontSize="10.5"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1"
                              Style="{StaticResource ToggleCheckBox}"
                              IsChecked="{Binding CloseAfterDone}"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════
             EYLEMLER + PROGRESS
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Style="{StaticResource CardBorder}"
                Margin="18,8,18,0">
            <StackPanel>
                <!-- Durum satırı -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusMessage, Mode=OneWay}"
                               FontSize="12.5"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ProgressText, Mode=OneWay}"
                               FontSize="11.5"
                               Foreground="{StaticResource TextMutedBrush}"
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}, Mode=OneWay}"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Progress bar -->
                <ProgressBar Style="{StaticResource ModernProgressBar}"
                             Height="5" Minimum="0"
                             Maximum="{Binding ProgressMax, Mode=OneWay}"
                             Value="{Binding ProgressValue, Mode=OneWay}"
                             Margin="0,0,0,14"/>

                <!-- Buton satırı -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- ZIP Oluştur -->
                    <Button Grid.Column="0"
                            Content="&#9654;  ZIP Oluştur"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding StartCommand}"
                            Padding="0,10"
                            Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}, Mode=OneWay}"/>

                    <!-- İptal -->
                    <Button Grid.Column="0"
                            Content="&#9632;  İptal Et"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelCommand}"
                            Padding="0,10"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}, Mode=OneWay}"/>

                    <!-- Klasörü Aç -->
                    <Button Grid.Column="2"
                            Content="&#128193;  Klasörü Aç"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding OpenResultCommand}"
                            Padding="14,10"
                            Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}, Mode=OneWay}"/>

                    <!-- Yazdır — yeşil vurgu -->
                    <Button Grid.Column="4"
                            Content="&#128424;  Yazdır"
                            Style="{StaticResource SuccessButton}"
                            Command="{Binding PrintCommand}"
                            Padding="14,10"
                            Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}, Mode=OneWay}"/>

                    <!-- Log Temizle -->
                    <Button Grid.Column="6"
                            Content="Logu Temizle"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding ClearLogCommand}"
                            Padding="12,10"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             İŞLEM LOGU
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="5"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="8"
                Margin="18,8,18,0"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Log başlığı — renkli -->
                <Border Grid.Row="0"
                        CornerRadius="8,8,0,0"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="14,8">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#F8FBFF" Offset="0"/>
                            <GradientStop Color="#F0F7FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Renkli şerit + başlık -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2"
                                    Background="{StaticResource AccentBrush}"
                                    Margin="0,0,7,0"/>
                            <TextBlock Text="İŞLEM LOGU"
                                       FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Kayıt sayısı badge -->
                        <Border Grid.Column="2"
                                CornerRadius="10" Padding="8,2"
                                Background="{StaticResource AccentLightBrush}"
                                Visibility="{Binding LogEntries.Count, Converter={StaticResource IntToVis}}">
                            <TextBlock FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}">
                                <Run Text="{Binding LogEntries.Count, Mode=OneWay}"/>
                                <Run Text=" kayıt"/>
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>

                <!-- Log satırları -->
                <ListBox Grid.Row="1"
                         x:Name="LogList"
                         Style="{StaticResource LogListBox}"
                         ItemsSource="{Binding LogEntries, Mode=OneWay}"
                         Background="{StaticResource BgSurfaceBrush}"
                         BorderThickness="0"
                         Padding="8,6">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="62"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding TimeDisplay}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="10.5" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Level, Converter={StaticResource LevelToIcon}}"
                                           Foreground="{Binding Level, Converter={StaticResource LevelToBrush}}"
                                           FontSize="10.5" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Message}"
                                           Foreground="{Binding Level, Converter={StaticResource LevelToBrush}}"
                                           TextWrapping="Wrap" FontSize="11.5"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             STATUS BAR
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="6"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding LastResultSummary, Mode=OneWay}"
                           FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Column="1" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center">
                    <Run Text="PDF Toplayıcı"/>
                    <Run Text=" "/>
                    <Run Text="{Binding AppVersion, Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Border>

    </Grid>
</Window>
