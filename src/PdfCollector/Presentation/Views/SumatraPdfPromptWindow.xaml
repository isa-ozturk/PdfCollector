<Window x:Class="PdfCollector.Presentation.Views.SumatraPdfPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDF Yazdırma Motoru"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Border Margin="8">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="20"
                              ShadowDepth="2" Direction="270"/>
        </Border.Effect>
        <Border CornerRadius="8" Background="{StaticResource BgPageBrush}" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ── HEADER ─────────────────────────────────────────── -->
                <Border Grid.Row="0"
                        Background="{StaticResource TitleBarBrush}"
                        MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="20,0,0,0">
                        <Border Width="26" Height="26" CornerRadius="5"
                                Background="#33FFFFFF" Margin="0,0,12,0">
                            <TextBlock Text="⚠" FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="White"/>
                        </Border>
                        <TextBlock Text="PDF Yazdırma Motoru Bulunamadı"
                                   Foreground="White" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ── CONTENT ────────────────────────────────────────── -->
                <StackPanel Grid.Row="1" Margin="24,20,24,20">

                    <!-- Icon + title row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="46" Height="46" CornerRadius="10"
                                Background="{StaticResource WarningLightBrush}"
                                VerticalAlignment="Top">
                            <TextBlock Text="⚠" FontSize="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="SumatraPDF bulunamadı"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Güvenilir PDF yazdırma için gerekli bileşen eksik"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Description -->
                    <Border Margin="0,16,0,0"
                            Background="{StaticResource AccentLightBrush}"
                            CornerRadius="6"
                            Padding="14,12">
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   LineHeight="20">
                            <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">SumatraPDF</Run>
                            <Run>, PDF dosyalarını sisteminizde PDF görüntüleyici kurulu olmadan doğrudan yazıcıya gönderebilen hafif bir yazdırma motorudur. Uygulamamız bu bileşeni kullanarak güvenilir yazdırma işlemi gerçekleştirir.</Run>
                        </TextBlock>
                    </Border>

                    <!-- Button description hints -->
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="⬇  İndir (~20 MB)"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="SumatraPDF indirilir, bir daha sorulmaz"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="✕  Hayır"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="Bu uyarıyı bir daha gösterme"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                </StackPanel>

                <!-- ── FOOTER ─────────────────────────────────────────── -->
                <Border Grid.Row="2"
                        Background="{StaticResource BgSurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="24,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1"
                                Content="Şimdi Değil"
                                Style="{StaticResource SecondaryButton}"
                                Padding="14,8"
                                Click="BtnLater_Click"/>

                        <Button Grid.Column="3"
                                Content="Hayır, Sorma"
                                Style="{StaticResource SecondaryButton}"
                                Padding="14,8"
                                Click="BtnDecline_Click"/>

                        <Button Grid.Column="5"
                                Content="⬇  İndir"
                                Style="{StaticResource PrimaryButton}"
                                Padding="18,8"
                                Click="BtnDownload_Click"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>
